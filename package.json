{
  "name": "@muffin/element",
  "version": "0.9.3",
  "description": "Lightweight, composable frontend framework. Web Components based.",
  "main": "src/main.js",
  "module": "dist/element.esm.js",
  "browser": "dist/element.min.js",
  "exports": {
    ".": {
      "import": "./src/main.js",
      "browser": "./dist/element.min.js"
    }
  },
  "bin": {
    "muf": "./cli/main.js"
  },
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production rollup -c",
    "build:dev": "rollup -c"
  },
  "keywords": ["frontend", "web-components", "spa", "vanilla"],
  "author": "footloose.io",
  "license": "Copyright © Footloose Labs INC.",
  "dependencies": {
    "localforage": "^1.10.0"
  },
  "optionalDependencies": {
    "commander": "^12.0.0",
    "kill-port": "^2.0.1"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-replace": "^5.0.0"
  }
}
